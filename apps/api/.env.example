# LLM provider keys (필요한 것만 채워도 됨)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# DB (Postgres + pgvector) — 로컬은 `docker compose up -d`로 기동(포트 5434)
DATABASE_URL="postgresql://aidiary:aidiary@localhost:5434/aidiary?schema=public"

# 인증 — 액세스 토큰 서명 시크릿 (랜덤: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=
# 소셜 로그인 provider 토큰 검증용 client id (모바일 OAuth 연결 시 채움)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# 서버 포트 / CORS
PORT=9001
WEB_ORIGIN=http://localhost:9000

# (선택) 모델 id override — 비전 caption에 쓸 모델
VISION_MODEL_ID=

# (선택) 음성 답변 전사(STT)에 쓸 OpenAI 모델 — 미설정 시 gpt-4o-transcribe
STT_MODEL_ID=
