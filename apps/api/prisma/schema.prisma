generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 소셜 로그인 유저. provider+providerId로 식별(Apple/Google/Kakao/dev).
model User {
  id         String   @id @default(uuid())
  provider   String // 'apple' | 'google' | 'kakao' | 'dev'
  providerId String // provider가 준 고유 id (sub 등)
  email      String?
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conversations Conversation[]

  @@unique([provider, providerId])
}

model Conversation {
  id          String   @id @default(uuid())
  /// 소유 유저. 인증 배선 전 익명 대화 허용을 위해 nullable(이후 필수화 예정).
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  format      String // 'plain' | 'newspaper' | 'novel'
  modelId     String
  latitude    Float?
  longitude   Float?
  weatherNote String? // 대화 시작 시점의 현재 위치 날씨 (예: "서울특별시 명동 · 맑음, 27°C (낮)")
  /// 인터뷰 수집 상태(JSON: CollectionState) — 하루 누적. 매 대화 턴 updateCollectionState 툴이 갱신. (s3.2 §3 A1-c)
  collectionState String?
  createdAt   DateTime @default(now())

  messages    Message[]
  attachments Attachment[]
  diary       Diary?
  llmUsages   LlmUsage[]
  feedback    Feedback?
}

/// 테스트 후 사람이 남기는 줄글 피드백 — agent 개선 분석용
model Feedback {
  id             String   @id @default(uuid())
  conversationId String   @unique
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String // 'user' | 'assistant'
  content        String
  parts          String? // JSON string: attachments / tool calls
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Attachment {
  id             String   @id @default(uuid())
  conversationId String
  messageId      String?
  filePath       String
  mimeType       String
  caption        String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Diary {
  id             String   @id @default(uuid())
  conversationId String   @unique
  format         String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

/// 가벼운 비용 집계 row — 표시/쿼리용
model LlmUsage {
  id              String   @id @default(uuid())
  traceId         String
  conversationId  String
  step            String // first_greeting | chat_turn | photo_caption | diary_generation
  modelId         String
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cacheReadTokens Int      @default(0)
  costUsd         Float    @default(0)
  status          String // success | failure
  durationMs      Int      @default(0)
  errorSummary    String?
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  trace        LlmCallTrace?

  @@index([conversationId, createdAt])
  @@index([traceId])
}

/// raw 입출력 보존 — 개선점 분석용
model LlmCallTrace {
  id              String   @id @default(uuid())
  llmUsageId      String   @unique
  traceId         String
  requestPayload  String // JSON
  responsePayload String? // JSON
  createdAt       DateTime @default(now())

  usage LlmUsage @relation(fields: [llmUsageId], references: [id], onDelete: Cascade)

  @@index([traceId])
}
