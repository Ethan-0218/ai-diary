# App Store Connect API 키 (fastlane 인증) — 이 파일을 fastlane/.env 로 복사해 채운다(.env는 커밋 금지).
# 발급: ASC → Users and Access → Integrations → App Store Connect API → "+" → 역할 App Manager 이상 → Generate
#  - .p8 파일은 생성 직후 1회만 다운로드됨. 안전한 곳에 두고 아래 경로 지정.
#  - Key ID / Issuer ID 는 그 페이지에 표시됨.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8
