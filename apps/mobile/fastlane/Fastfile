default_platform(:ios)

# App Store Connect API 키로 인증한다(2FA 없이 자동화).
# fastlane/.env 에 다음을 둔다(커밋 금지):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH(=AuthKey_XXXX.p8 경로)
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    in_house: false,
  )
end

platform :ios do
  desc "Release 빌드 → TestFlight 업로드"
  lane :beta do
    api_key = asc_api_key

    build_app(
      workspace: "AiDiary.xcworkspace",
      scheme: "AiDiary",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  # 재업로드는 빌드번호가 유일해야 한다. 다음 업로드 전 한 번 실행:
  #   bundle exec fastlane bump
  desc "빌드번호 +1 (재업로드 전)"
  lane :bump do
    increment_build_number(xcodeproj: "AiDiary.xcodeproj")
  end
end
